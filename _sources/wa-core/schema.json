{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "WA profile of Cadastral Survey Data Model",
  "x-jsonld-context": "context.jsonld",
  "allOf": [
    {
      "$ref": "bblocks://icsm.profiles.common"
    },
    {
      "properties": {
        "parcels": {
          "type": "array",
          "items": {
            "properties": {
              "features": {
                "type": "array",
                "items": {
                  "properties": {
                    "properties": {
                      "properties": {
                        "appellation": {
                          "$ref": "bblocks://icsm.profiles.wa.datatypes.parcelAppellation"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
