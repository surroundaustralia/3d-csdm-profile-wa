  "transforms": [
    {
      "id": "Dual-name-label",
      "description": "Python snippet (no dependencies) that creates a multilingual label using indigenous label first if present",
      "type": "python",
      "inputs": {
        "mediaTypes": [
          {
            "mimeType": "application/json",
            "label": "JSON",
            "defaultExtension": "json"
          }
        ]
      },
      "outputs": {
        "mediaTypes": [
          {
            "mimeType": "text/plain"
          }
        ],
        "defaultExtension": "txt"
      },
      "code": "import json\ndata = json.loads(input_data)\ncatype = \"\"\nlnumber = \"\"\nareaCode = \"Plan\"\nfor p in data['hasPart']:\n    if p['type'] == 'crownAreaCode':\n      if 'ref' in p:\n        areaCode = p['ref'].split(\":\")[1].title()\n      else:\n        areaCode = \"Not Defined\"\n    elif  p['type'] == 'crownAllocationType':\n      catype = \"Town Lot\"\n    elif  p['type'] == 'number':\n      lnumber = p['label']\noutput_data=f\"{areaCode} {catype} {lnumber}\"\n"
    }
  ],
