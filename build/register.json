      "transforms": [
        {
          "id": "Dual-name-label",
          "description": "Python snippet (no dependencies) that creates a multilingual label using indigenous label first if present",
          "type": "python",
          "inputs": {
            "mediaTypes": [
              {
                "mimeType": "application/json",
                "label": "JSON",
                "defaultExtension": "json"
              }
            ]
          },
          "outputs": {
            "mediaTypes": [
              {
                "mimeType": "application/json",
                "label": "JSON",
                "defaultExtension": "json"
              }
            ]
          },
          "code": "import json\ndata = json.loads(input_data)\nimport json\nen_label=\"\"\nin_label=\"\"\nslash=\"\"\nfor p in data['hasPart']:\n    if p['type'] == 'wa:indigenousName':\n        in_label = p['label']\n    elif  p['type'] == 'wa:placeName':\n        en_label = p['label']\nif in_label and en_label:\n    slash = \" / \"\noutput_data=f\"{in_label}{slash}{en_label}\"\n"
        }
      ],
